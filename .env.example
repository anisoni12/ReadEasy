# ============================================================================
# ReadEasy — Environment Variables Template
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# Only the AI variables are strictly required for the app to run.
# ============================================================================


# ----------------------------------------------------------------------------
# Google Gemini (REQUIRED for all AI features:
#   summarize, explain, vocabulary, auto book detection)
# ----------------------------------------------------------------------------
# Get a free API key from Google AI Studio: https://aistudio.google.com/apikey
AI_INTEGRATIONS_GEMINI_API_KEY=

# Base URL for the Gemini API.
# For Google's official Gemini API, use:
#   https://generativelanguage.googleapis.com
AI_INTEGRATIONS_GEMINI_BASE_URL=


# ----------------------------------------------------------------------------
# Server config (OPTIONAL — sensible defaults are used if blank)
# ----------------------------------------------------------------------------
# Node environment: development | production
NODE_ENV=development

# Log verbosity: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Random string used to sign sessions (reserved for future use).
# You can generate one with:  openssl rand -base64 32
SESSION_SECRET=


# ----------------------------------------------------------------------------
# Database (NOT used by ReadEasy itself — the app stores everything locally
# in the browser. This is only here because the monorepo includes a DB lib.
# Leave blank unless you add features that need a database.)
# ----------------------------------------------------------------------------
DATABASE_URL=


# ----------------------------------------------------------------------------
# Replit-managed (DO NOT SET MANUALLY)
# ----------------------------------------------------------------------------
# These are injected automatically by Replit workflows when running on Replit.
# If you run outside Replit, set PORT to whatever port you want each service
# to listen on (e.g. 8080 for the API, 5173 for the web app).
# PORT=
# BASE_PATH=
# REPL_ID=
